    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 5,
    "bbox": [
      248.0,
      406.77,
      430.68,
      451.34
    ],
    "text": "There may be a profit as well as a loss in business activities. Businesses will have to face these uncertainties.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 5,
    "bbox": [
      69.0,
      498.1,
      150.55,
      528.27
    ],
    "text": "Transactions are based on price",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
