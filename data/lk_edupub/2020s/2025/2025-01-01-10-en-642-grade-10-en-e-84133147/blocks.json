    ]
  },
  {
    "page_number": 8,
    "bbox": [
      72.0,
      452.1,
      257.03,
      473.43
    ],
    "text": "2.6 Types of entrepreneurs",
    "fonts": [
      "TimesNewRomanPS-BoldMT"
    ],
    "sizes": [
      16.0
    ]
  },
  {
    "page_number": 8,
    "bbox": [
      72.0,
      490.2,
      287.3,
      505.96
    ],
    "text": "We can identify three types of entrepreneurs.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 8,
    "bbox": [
      72.0,
      515.92,
      214.23,
      534.58
    ],
    "text": "Business Entrepreneurs",
    "fonts": [
      "TimesNewRomanPS-BoldMT"
    ],
    "sizes": [
      14.0
    ]
  },
  {
    "page_number": 8,
    "bbox": [
      72.0,
      546.2,
      471.03,
      575.97
    ],
    "text": "These are the traders or businessmen who involve in business activities with the motives of earning profits.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 8,
    "bbox": [
      72.0,
      587.9,
      274.0,
      617.97
    ],
    "text": "Example :- Retail trading businessman",
    "fonts": [
      "FMAbhaya",
      "TimesNewRomanPS-BoldItal",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 9,
    "bbox": [
      56.88,
      630.68,
      292.28,
      655.88
    ],
    "text": "For free distribution34",
