  {
    "page_number": 6,
    "bbox": [
      72.4,
      105.64,
      340.93,
      189.83
    ],
    "text": "\u2022 Open the door very slowly and quietly.\u2022 My little brother is splashing water in the pool noisily.\u2022 Can you come here quickly?\u2022 We sometimes go out for dinner.\u2022 They usually lock the door when they go out.",
    "fonts": [
      "TimesNewRomanPSMT"
