    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 5,
    "bbox": [
      72.0,
      131.26,
      322.14,
      176.22
    ],
    "text": "\u2022 Polythene bags have been thrown away carelessly.\u2022 We have worked very hard.\u2022 Place the date directly below the address.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
