    ],
    "text": "3. The dentist advised the child to brush his teeth \u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026 going to bed.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 5,
    "bbox": [
      72.0,
      150.84,
      450.1,
