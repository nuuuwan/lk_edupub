      71.99,
      397.48,
      108.84,
      413.65
    ],
    "text": "Writing",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      71.99,
      427.19,
      452.7,
      485.65
    ],
    "text": "Work in small groups.Read the information given about popular tourist destinations in Sri Lanka. Select one place and find more information and pictures of that place. Then write an article about it to be displayed on your wall newspaper.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      78.0,
      627.64,
      446.13,
      652.76
    ],
    "text": "94For free distribution",
    "fonts": [
      "Cambria-Italic",
